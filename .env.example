# Django
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Supabase Postgres connection string)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eld_planner

# CORS — comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173

# CSRF — comma-separated origins (with scheme) trusted for unsafe-method requests.
# Required for the Django admin to work over HTTPS on a custom domain.
# On Railway, RAILWAY_PUBLIC_DOMAIN is auto-appended to this list at runtime.
CSRF_TRUSTED_ORIGINS=


# Routing services
OSRM_BASE_URL=https://router.project-osrm.org
ORS_BASE_URL=https://api.openrouteservice.org
ORS_API_KEY=

# Geocoding (Nominatim requires a descriptive User-Agent per their TOS)
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=eld-trip-planner/0.1 (contact: you@example.com)
